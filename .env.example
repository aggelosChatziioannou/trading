# ============================================
# GOLD TACTIC — Environment Configuration
# Copy this file to .env and fill in your keys
# ============================================

# Alpaca Paper Trading API
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Finnhub API (free tier available at finnhub.io)
FINNHUB_API_KEY=your_finnhub_key_here

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL=your_channel_id_here

# Moonshot Kimi API (required only if using Kimi Code CLI / Kimi Claw)
KIMI_API_KEY=your_kimi_api_key_here

# Optional: CryptoPanic API key (free tier at cryptopanic.com/developers/api/)
CRYPTOPANIC_API_KEY=
