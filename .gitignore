# Environment variables
# .env is committed — contains only free Telegram API credentials (no billing keys)
.env.local
.env.secret

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# Data
data/raw/
data/processed/
*.csv

# Global JSON exclusion (overridden below for GOLD_TACTIC)
*.json
!data/.gitkeep
!.mcp.json

# GOLD_TACTIC — include scripts, prompts, data templates, backtest results
!GOLD_TACTIC/scripts/**
!GOLD_TACTIC/prompts/**
!GOLD_TACTIC/backtest/**
# GOLD_TACTIC — include empty templates only (runtime data excluded)
!GOLD_TACTIC/data/.gitkeep
!GOLD_TACTIC/data/emergency_activations.json
!GOLD_TACTIC/data/narrative_memory.json
!GOLD_TACTIC/data/news_digest.json
!GOLD_TACTIC/data/regime_state.json
!GOLD_TACTIC/data/research_notes.md
# v7.4 self-improvement core state files (must be committed to seed agent state)
!GOLD_TACTIC/data/edge_weights.json
!GOLD_TACTIC/data/learned_patterns.json
!GOLD_TACTIC/data/agent_calibration.json
!GOLD_TACTIC/data/daily_observations/.gitkeep
# v7.4 archive folder for untrusted backtest data
!GOLD_TACTIC/_archive/**

